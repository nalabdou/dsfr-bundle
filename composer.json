{
    "name": "nalabdou/dsfr-bundle",
    "description": "Symfony bundle for the French Government Design System (DSFR)",
    "type": "symfony-bundle",
    "license": "Apache-2.0",
    "keywords": [
        "symfony",
        "bundle",
        "dsfr",
        "design-system",
        "twig",
        "french-government",
        "accessibility",
        "rgaa"
    ],
    "authors": [
        {
            "name": "Nadim Al Abdou",
            "email": "nadim.alabdou@gmail.com",
            "homepage": "https://github.com/nalabdou"
        }
    ],
    "homepage": "https://github.com/nalabdou/dsfr-bundle",
    "support": {
        "issues": "https://github.com/nalabdou/dsfr-bundle/issues",
        "source": "https://github.com/nalabdou/dsfr-bundle"
    },
    "require": {
        "php": "^8.3",
        "symfony/framework-bundle": "^6.4 || ^7.4",
        "symfony/ux-twig-component": "^2.13",
        "symfony/options-resolver": "^6.4 || ^7.4",
        "symfony/http-kernel": "^6.4 || ^7.4",
        "symfony/dependency-injection": "^6.4 || ^7.4",
        "symfony/config": "^6.4 || ^7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "^6.4 || ^7.4",
        "symfony/phpunit-bridge": "^6.4 || ^7.4",
        "nyholm/symfony-bundle-test": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Nalabdou\\Dsfr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nalabdou\\Dsfr\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "symfony/flex": true
        }
    },
    "extra": {
        "symfony": {
            "require": "^6.4 || ^7.4"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
